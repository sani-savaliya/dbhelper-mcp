{
  "name": "dbhelper-mcp",
  "version": "1.0.0",
  "description": "MCP server for read-only SQL Server database access. Query schemas, tables, stored procedures, and compare data across multiple databases.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dbhelper-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sql-server",
    "mssql",
    "database",
    "claude",
    "ai-tools",
    "read-only"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "mssql": "^11.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
