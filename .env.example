# dbhelper-mcp — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# Read-only SQL credentials (created via sql/create-readonly-user.sql)
SQL_READONLY_USER=your_readonly_user
SQL_READONLY_PASSWORD=your_password_here

# (Optional) Path to databases.json config file.
# Defaults to ./databases.json next to the package root.
# DBHELPER_CONFIG=/path/to/databases.json
